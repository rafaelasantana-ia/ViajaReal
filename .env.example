# Backend: Ollama local por padrão. Groq continua disponível como alternativa.
AI_MODE=real
AI_PROVIDER=ollama
AI_TIMEOUT_SECONDS=90
AI_MAX_TOKENS=600
AI_MAX_TOOL_CYCLES=2
AI_MODEL=llama3.2
OLLAMA_API_URL=http://127.0.0.1:11434/v1

# Usado somente quando AI_PROVIDER=groq. Nunca envie a chave para o Git.
AI_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=cole-sua-chave-somente-no-arquivo-.env
FRONTEND_ORIGINS=http://localhost:5173

# APIs externas. A chave da Pexels fica somente no backend.
PEXELS_API_KEY=cole-sua-chave-da-pexels-aqui
EXTERNAL_API_TIMEOUT=8
CACHE_TTL=3600
NOMINATIM_USER_AGENT=ViajaReal/1.0 (+https://github.com/rafaelasantana-ia/ViajaReal)

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
